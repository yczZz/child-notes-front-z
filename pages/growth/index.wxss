/* pages/growth/index.wxss */

.growth-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #fef9f0 0%, #fdf5e6 10%, #fafafa 40%);
  padding-bottom: calc(120rpx + env(safe-area-inset-bottom));
}

/* 头部 */
.g-header {
  text-align: center;
  padding: 60rpx 40rpx 40rpx;
}

.g-header-icon { font-size: 72rpx; margin-bottom: 16rpx; }
.g-header-title { font-size: 40rpx; font-weight: 700; color: #5d4037; margin-bottom: 8rpx; }
.g-header-sub { font-size: 26rpx; color: #a1887f; }

/* 时间轴 */
.g-timeline {
  padding: 0 40rpx 0 60rpx;
  position: relative;
}

.g-timeline::before {
  content: '';
  position: absolute;
  left: 58rpx; top: 0; bottom: 0;
  width: 4rpx;
  background: linear-gradient(180deg, #ffcc80, #ffab91, #ef9a9a, #f8bbd0);
  border-radius: 2rpx;
}

.g-node {
  position: relative;
  margin-bottom: 40rpx;
}

/* 日期徽章 */
.g-date-badge {
  position: absolute;
  left: -54rpx; top: 0;
  width: 112rpx; text-align: center;
  background: #fff;
  border: 3rpx solid #ffab91;
  border-radius: 20rpx;
  padding: 8rpx 0;
  font-size: 22rpx; color: #e65100; font-weight: 600;
  z-index: 2;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.g-badge-add { border-color: #ccc; color: #999; }
.g-plus { font-size: 36rpx; font-weight: 300; color: #bbb; }

/* 卡片 */
.g-card {
  margin-left: 76rpx;
  background: #fff;
  border-radius: 20rpx;
  padding: 28rpx;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
  border-left: 6rpx solid #ffab91;
}

.g-card-add {
  border-left: 6rpx dashed #ddd;
  background: #fafafa;
  text-align: center;
  padding: 32rpx;
}

.g-add-text { font-size: 28rpx; color: #bbb; }

.g-card-title { font-size: 32rpx; font-weight: 700; color: #4e342e; margin-bottom: 10rpx; }
.g-card-text { font-size: 26rpx; color: #8d6e63; line-height: 1.7; }
.g-card-imgs { display: flex; gap: 12rpx; margin-top: 16rpx; }
.g-img { width: 140rpx; height: 140rpx; border-radius: 12rpx; background: #f5f5f5; }

.g-line-end { height: 40rpx; }

/* 弹窗 */
.g-mask {
  position: fixed; left:0; right:0; top:0; bottom:0;
  z-index:10000; background:rgba(0,0,0,0.4);
  display:flex; align-items:flex-end;
}

.g-sheet {
  width:100%; background:#fff;
  border-radius:24rpx 24rpx 0 0;
  padding:32rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  max-height:85vh; overflow-y:auto;
}

.g-sheet-hd { display:flex; align-items:center; margin-bottom:28rpx; }
.g-sheet-title { flex:1; font-size:34rpx; font-weight:700; color:#222; }
.g-sheet-close { font-size:40rpx; color:#bbb; padding:8rpx; }
.g-form-item { margin-bottom:28rpx; }
.g-form-label { font-size:28rpx; color:#666; margin-bottom:14rpx; }
.req { color:#e74c3c; }
.g-form-input {
  width:100%; height:88rpx; background:#f5f5f5; border-radius:12rpx;
  padding:0 24rpx; font-size:28rpx; box-sizing:border-box;
}
.g-form-picker {
  height:88rpx; line-height:88rpx; background:#f5f5f5; border-radius:12rpx;
  padding:0 24rpx; font-size:28rpx; color:#333;
}
.g-form-picker.placeholder { color:#ccc; }
.g-form-textarea {
  width:100%; min-height:160rpx; background:#f5f5f5; border-radius:12rpx;
  padding:18rpx 24rpx; font-size:28rpx; box-sizing:border-box;
}
.g-photo-grid { display:flex; gap:14rpx; flex-wrap:wrap; }
.g-photo-item {
  width:140rpx; height:140rpx; border-radius:12rpx; overflow:hidden; position:relative;
}
.g-photo-item image { width:100%; height:100%; }
.g-photo-del {
  position:absolute; top:4rpx; right:4rpx;
  width:36rpx; height:36rpx; border-radius:50%;
  background:rgba(0,0,0,0.5); color:#fff; font-size:22rpx;
  display:flex; align-items:center; justify-content:center;
}
.g-photo-add {
  width:140rpx; height:140rpx; border-radius:12rpx;
  border:2rpx dashed #d0d0d0; background:#fafafa;
  display:flex; align-items:center; justify-content:center;
}
.add-plus { font-size:52rpx; color:#ccc; }
.g-save-btn {
  margin-top:20rpx; width:100%; height:88rpx; line-height:88rpx;
  background:#ff7043; color:#fff; border-radius:16rpx;
  font-size:30rpx; font-weight:600; padding:0; text-align:center;
}
