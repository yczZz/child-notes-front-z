/* pages/baby-setup/index.wxss */

.setup-page {
  min-height: 100vh;
  background: linear-gradient(180deg, #e8f9ef 0%, #f5f5f5 40%);
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 60rpx 40rpx;
  box-sizing: border-box;
}

.setup-card {
  width: 100%;
  background: #fff;
  border-radius: 24rpx;
  padding: 60rpx 40rpx 40rpx;
  box-shadow: 0 8rpx 40rpx rgba(0, 0, 0, 0.06);
}

.setup-header {
  text-align: center;
  margin-bottom: 50rpx;
}

.setup-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.setup-title {
  font-size: 38rpx;
  font-weight: 700;
  color: #222;
  margin-bottom: 12rpx;
}

.setup-desc {
  font-size: 28rpx;
  color: #999;
}

/* 性别选择 */
.gender-switch {
  display: flex;
  align-items: center;
  padding: 20rpx 0 30rpx;
}

.gender-label {
  width: 120rpx;
  color: #333;
  font-size: 30rpx;
}

.gender-options {
  display: flex;
  gap: 20rpx;
}

.gender-btn {
  padding: 18rpx 36rpx;
  border-radius: 40rpx;
  background: #f5f5f5;
  font-size: 28rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.gender-btn.active {
  background: #e8f9ef;
  color: #07c160;
  border-color: #07c160;
  font-weight: 600;
}

/* 表单行 */
.form-row {
  display: flex;
  align-items: center;
  height: 96rpx;
  border-top: 1rpx solid #f0f0f0;
  border-bottom: 1rpx solid #f0f0f0;
}

.form-label {
  width: 120rpx;
  color: #333;
  font-size: 30rpx;
}

.form-input {
  flex: 1;
  height: 96rpx;
  line-height: 96rpx;
  color: #222;
  font-size: 30rpx;
}

.form-input.picker-val {
  display: flex;
  align-items: center;
}

.form-input.placeholder {
  color: #ccc;
}

.form-arrow {
  font-size: 36rpx;
  color: #ccc;
  margin-left: 10rpx;
}

/* 保存按钮 */
.save-btn {
  margin-top: 50rpx;
  width: 100%;
  height: 96rpx;
  line-height: 96rpx;
  border-radius: 48rpx;
  background: #07c160;
  color: #fff;
  font-size: 34rpx;
  font-weight: 600;
  padding: 0;
  text-align: center;
  box-sizing: border-box;
}

/* 跳过 */
.skip-link {
  text-align: center;
  margin-top: 30rpx;
  font-size: 28rpx;
  color: #bbb;
  padding: 10rpx;
}
