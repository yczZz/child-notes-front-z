.points-page {
  min-height: 100vh;
  background: #f2f4f7;
  padding: 24rpx 24rpx calc(120rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.zone {
  background: #fff;
  border-radius: 16rpx;
  padding: 28rpx;
  margin-bottom: 22rpx;
  box-shadow: 0 2rpx 14rpx rgba(30, 41, 59, 0.04);
  box-sizing: border-box;
}

.asset-card {
  padding: 30rpx 28rpx;
  border-radius: 16rpx;
  background: linear-gradient(135deg, #ecf8f1, #fff7ef);
}

.asset-label {
  font-size: 26rpx;
  color: #5b6b62;
  margin-bottom: 8rpx;
}

.asset-value {
  color: #18251e;
  font-size: 64rpx;
  font-weight: 800;
  line-height: 1.1;
}

.asset-value text {
  margin-left: 8rpx;
  font-size: 28rpx;
  font-weight: 600;
}

.asset-sub {
  margin-top: 10rpx;
  font-size: 24rpx;
  color: #718078;
}

.timeline {
  display: grid;
  grid-template-columns: repeat(7, minmax(0, 1fr));
  gap: 8rpx;
  margin: 30rpx 0 28rpx;
}

.timeline-item {
  min-width: 0;
  text-align: center;
}

.timeline-date {
  font-size: 22rpx;
  color: #8a8f98;
  margin-bottom: 12rpx;
  white-space: nowrap;
}

.timeline-dot {
  width: 64rpx;
  height: 64rpx;
  line-height: 64rpx;
  margin: 0 auto;
  border-radius: 50%;
  background: #eef1f4;
  color: #9aa1aa;
  font-size: 22rpx;
  font-weight: 700;
}

.timeline-item.signed .timeline-dot {
  background: #e8f7ee;
  color: #07a85a;
}

.timeline-item.today .timeline-date {
  color: #e86f24;
  font-weight: 700;
}

.timeline-item.today .timeline-dot {
  box-shadow: 0 0 0 4rpx rgba(232, 111, 36, 0.14);
}

.primary-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 16rpx;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
  padding: 0;
  text-align: center;
}

.primary-btn::after {
  border: none;
}

.primary-btn[disabled] {
  color: rgba(255,255,255,0.88);
}

.sign-btn {
  background: #07c160;
}

.sign-btn[disabled] {
  background: #8bd9ad;
}

.lottery-btn {
  margin-top: 24rpx;
  background: #e84d3d;
}

.lottery-btn[disabled] {
  background: #e7aaa3;
}

.hint {
  margin-top: 16rpx;
  text-align: center;
  color: #7b8490;
  font-size: 24rpx;
}

.zone-head {
  display: flex;
  align-items: center;
  margin-bottom: 24rpx;
}

.zone-title {
  flex: 1;
  font-size: 32rpx;
  font-weight: 800;
  color: #1e293b;
}

.draw-time {
  flex: 1;
  min-width: 0;
  color: #d93025;
  font-size: 26rpx;
  font-weight: 700;
}

.history-link {
  color: #2563eb;
  font-size: 26rpx;
  flex-shrink: 0;
}

.prize {
  display: flex;
  gap: 20rpx;
  align-items: stretch;
}

.prize-image {
  width: 180rpx;
  height: 180rpx;
  border-radius: 12rpx;
  background: #f0f2f5;
  flex-shrink: 0;
}

.prize-body {
  flex: 1;
  min-width: 0;
  display: flex;
  flex-direction: column;
}

.prize-name {
  font-size: 34rpx;
  font-weight: 800;
  color: #111827;
  margin-bottom: 10rpx;
}

.prize-intro {
  color: #4b5563;
  font-size: 26rpx;
  line-height: 1.45;
}

.prize-meta {
  margin-top: auto;
  padding-top: 12rpx;
  color: #8b95a1;
  font-size: 22rpx;
}

.avatar-row {
  display: flex;
  align-items: center;
  min-height: 58rpx;
  margin-top: 24rpx;
}

.join-avatar {
  width: 56rpx;
  height: 56rpx;
  border-radius: 50%;
  border: 3rpx solid #fff;
  margin-right: -12rpx;
  background: #e5e7eb;
}

.avatar-empty {
  font-size: 24rpx;
  color: #9ca3af;
}

.task-item {
  width: 100%;
  display: flex;
  align-items: center;
  justify-content: space-between;
  min-height: 118rpx;
  padding: 18rpx 0;
  margin: 0;
  background: transparent;
  border-bottom: 1rpx solid #f0f2f5;
}

.task-item:last-child {
  border-bottom: none;
}

.task-left {
  display: flex;
  align-items: center;
  min-width: 0;
  flex: 1;
  margin-right: 20rpx;
}

.task-points {
  width: 76rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 50%;
  text-align: center;
  background: #fff0df;
  color: #e86f24;
  font-size: 24rpx;
  font-weight: 800;
  flex-shrink: 0;
  margin-right: 18rpx;
}

.task-body {
  flex: 1;
  min-width: 0;
}

.task-title {
  color: #1f2937;
  font-size: 30rpx;
  font-weight: 800;
  margin-bottom: 8rpx;
}

.task-desc {
  color: #77808c;
  font-size: 24rpx;
}

.task-action {
  width: 100px;
  min-width: 100px;
  max-width: 100px;
  height: 48rpx;
  line-height: 1;
  margin: 0;
  padding: 0;
  border-radius: 24rpx;
  background: #07c160;
  color: #fff;
  font-size: 18rpx;
  font-weight: 700;
  display: inline-flex;
  align-items: center;
  justify-content: center;
  box-sizing: border-box;
  text-align: center;
  white-space: nowrap;
  overflow: hidden;
  flex-shrink: 0;
}

.task-action::after {
  border: none;
}

.sheet-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 10000;
  background: rgba(15, 23, 42, 0.42);
  display: flex;
  align-items: flex-end;
}

.sheet {
  width: 100%;
  max-height: 72vh;
  overflow-y: auto;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 30rpx 28rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.sheet-head {
  display: flex;
  align-items: center;
  margin-bottom: 20rpx;
}

.sheet-title {
  flex: 1;
  font-size: 34rpx;
  font-weight: 800;
  color: #1f2937;
}

.sheet-close {
  color: #9ca3af;
  font-size: 44rpx;
  padding: 4rpx 10rpx;
}

.empty {
  padding: 42rpx 0;
  text-align: center;
  color: #9ca3af;
  font-size: 26rpx;
}

.record-row {
  display: flex;
  align-items: center;
  padding: 20rpx 0;
  border-bottom: 1rpx solid #f0f2f5;
}

.record-avatar,
.history-badge {
  width: 70rpx;
  height: 70rpx;
  border-radius: 50%;
  margin-right: 18rpx;
  flex-shrink: 0;
}

.record-avatar.placeholder,
.history-badge {
  display: flex;
  align-items: center;
  justify-content: center;
  background: #e8f7ee;
  color: #07a85a;
  font-size: 26rpx;
  font-weight: 800;
}

.record-body {
  flex: 1;
  min-width: 0;
}

.record-title {
  font-size: 28rpx;
  color: #1f2937;
  font-weight: 700;
  margin-bottom: 6rpx;
}

.record-time {
  font-size: 22rpx;
  color: #8992a0;
}

.record-points {
  color: #e86f24;
  font-size: 28rpx;
  font-weight: 800;
}

.history-status {
  color: #64748b;
  font-size: 24rpx;
  flex-shrink: 0;
}
