/* pages/feeding/index.wxss */

.feeding-page {
  min-height: 100vh;
  background: #f5f5f5;
  padding-bottom: 160rpx;
}

/* 日期选择器 */
.date-bar {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.date-display {
  text-align: center;
  padding: 0 20rpx;
}

.date-row {
  display: flex;
  align-items: center;
  gap: 12rpx;
}

.date-text {
  font-size: 34rpx;
  font-weight: bold;
  color: #333;
}

.date-text-weekday {
  font-size: 24rpx;
  color: #999;
}

.calendar-icon {
  font-size: 24rpx;
  opacity: 0.5;
}

.date-nav {
  width: 72rpx;
  height: 72rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #07c160;
  font-weight: 300;
  border-radius: 50%;
}

.date-nav:active {
  background: #e8f9ef;
}

/* 回到今天 */
.today-btn {
  text-align: center;
  padding: 16rpx;
  font-size: 26rpx;
  color: #07c160;
  background: #e8f9ef;
}

/* 摘要 */
.day-summary {
  display: flex;
  flex-wrap: wrap;
  justify-content: center;
  gap: 12rpx 24rpx;
  padding: 18rpx 32rpx;
  background: #fff;
  border-bottom: 1rpx solid #f0f0f0;
}

.summary-item {
  font-size: 24rpx;
  color: #666;
  line-height: 1.5;
  white-space: nowrap;
}

/* 记录列表 */
.records-list {
  padding: 24rpx 32rpx;
}

.swipe-row {
  position: relative;
  overflow: hidden;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  background: transparent;
}

.delete-action {
  position: absolute;
  top: 2rpx;
  right: 0;
  bottom: 2rpx;
  width: 144rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  background: #fa5151;
  color: #fff;
  font-size: 28rpx;
  font-weight: 600;
  z-index: 0;
  opacity: 0;
  pointer-events: none;
  transform: translate3d(24rpx, 0, 0);
  transition: opacity 220ms ease, transform 220ms cubic-bezier(0.2, 0.8, 0.2, 1);
  border-radius: 0 14rpx 14rpx 0;
}

.delete-action.active {
  opacity: 1;
  pointer-events: auto;
  transform: translate3d(0, 0, 0);
}

/* 记录卡片 */
.record-card {
  display: flex;
  align-items: center;
  padding: 24rpx;
  background: #fff;
  border-radius: 16rpx;
  margin-bottom: 16rpx;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.03);
  position: relative;
  overflow: hidden;
  z-index: 1;
  box-sizing: border-box;
  backface-visibility: hidden;
  transition: transform 240ms cubic-bezier(0.2, 0.8, 0.2, 1);
}

.swipe-row .record-card {
  margin-bottom: 0;
}

.record-card.swiping {
  transition: none;
}

.record-card.open {
  border-top-right-radius: 0;
  border-bottom-right-radius: 0;
}

/* 异常记录红色左边框 */
.record-card.abnormal::before {
  content: '';
  position: absolute;
  left: 0;
  top: 0;
  bottom: 0;
  width: 6rpx;
  background: #e74c3c;
  border-radius: 3rpx 0 0 3rpx;
}

.card-left {
  margin-right: 16rpx;
}

.card-time {
  font-size: 24rpx;
  color: #999;
  white-space: nowrap;
}

.card-icon {
  font-size: 40rpx;
  margin-right: 16rpx;
  width: 60rpx;
  height: 60rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 16rpx;
  background: #f9f9f9;
}

.card-body {
  flex: 1;
  min-width: 0;
}

.card-title {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.card-desc {
  font-size: 24rpx;
  color: #999;
  margin-top: 4rpx;
}

.card-note {
  display: inline-block;
  max-width: 100%;
  margin-top: 8rpx;
  padding: 8rpx 12rpx;
  border-radius: 8rpx;
  background: #f7f7f7;
  color: #666;
  font-size: 24rpx;
  line-height: 1.5;
  box-sizing: border-box;
  word-break: break-word;
}

.card-extra {
  font-size: 26rpx;
  color: #07c160;
  font-weight: 500;
  white-space: nowrap;
  margin-left: 16rpx;
}

.recovered-extra {
  padding: 6rpx 12rpx;
  border-radius: 20rpx;
  color: #07c160 !important;
  background: #e8f9ef;
}

/* 进行中的睡眠 */
.record-card.sleeping {
  background: #f0f7ff;
  border: 2rpx solid #c8d8f8;
}

.sleeping-extra {
  color: #3498db !important;
  animation: pulse-text 2s infinite;
}

.record-card.feeding-ongoing {
  background: #f0fff6;
  border: 2rpx solid #bcebcf;
}

.record-card.feeding-paused {
  background: #fffdf0;
  border: 2rpx solid #f1e1a8;
}

.record-card.maternal-food {
  background: #fbfff4;
  border: 2rpx solid #e2efd1;
}

.record-card.maternal-food.suspect {
  background: #fff8ef;
  border-color: #f5d4a8;
}

.feeding-extra {
  color: #07c160 !important;
  animation: pulse-text 2s infinite;
}

@keyframes pulse-text {
  0%, 100% { opacity: 1; }
  50% { opacity: 0.5; }
}

/* 唤醒按钮 */
.wake-btn {
  padding: 12rpx 24rpx;
  background: linear-gradient(135deg, #3498db, #2980b9);
  color: #fff;
  border-radius: 40rpx;
  font-size: 24rpx;
  font-weight: 500;
  animation: wake-pulse 1.8s infinite;
  white-space: nowrap;
  margin-left: 12rpx;
}

.wake-btn:active {
  transform: scale(0.95);
}

@keyframes wake-pulse {
  0%, 100% { box-shadow: 0 0 0 0 rgba(52, 152, 219, 0.4); }
  50% { box-shadow: 0 0 0 12rpx rgba(52, 152, 219, 0); }
}

/* 空状态 */
.empty-state {
  text-align: center;
  padding: 120rpx 0;
}

.empty-icon {
  font-size: 80rpx;
  margin-bottom: 20rpx;
}

.empty-text {
  font-size: 30rpx;
  color: #999;
  margin-bottom: 8rpx;
}

.empty-hint {
  font-size: 24rpx;
  color: #ccc;
}

/* 记录卡片中的照片 */
.card-photos {
  display: flex;
  flex-wrap: wrap;
  gap: 10rpx;
  margin-top: 12rpx;
}

.card-photo {
  width: 100rpx;
  height: 100rpx;
  border-radius: 8rpx;
  background: #f0f0f0;
}
