.family-page {
  min-height: 100vh;
  background: #ededed;
  padding: 24rpx 24rpx calc(48rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

/* ========== 状态提示 ========== */
.family-state {
  margin-top: 160rpx;
  text-align: center;
  color: #888;
}

.family-state-title {
  font-size: 32rpx;
  font-weight: 700;
  color: #333;
  margin-bottom: 12rpx;
}

.family-state-desc {
  font-size: 26rpx;
  padding: 0 40rpx;
  line-height: 1.6;
}

.family-empty-btn {
  margin-top: 36rpx;
  display: inline-block;
  padding: 18rpx 56rpx;
  border-radius: 40rpx;
  background: #07c160;
  color: #fff;
  font-size: 28rpx;
  line-height: 1;
}

/* ========== 家人列表 ========== */
.family-list {
  background: #fff;
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 14rpx rgba(0,0,0,0.03);
}

.family-member {
  display: flex;
  align-items: center;
  padding: 22rpx 24rpx;
  border-bottom: 1rpx solid #f5f5f5;
  box-sizing: border-box;
}

.family-member:last-child {
  border-bottom: none;
}

.family-member-avatar {
  width: 76rpx;
  height: 76rpx;
  border-radius: 50%;
  overflow: hidden;
  background: #f0f0f0;
  display: flex;
  align-items: center;
  justify-content: center;
  flex-shrink: 0;
  margin-right: 18rpx;
  font-size: 34rpx;
}

.family-member-avatar image {
  width: 100%;
  height: 100%;
}

.family-member-body {
  flex: 1;
  min-width: 0;
}

.family-member-top {
  display: flex;
  align-items: center;
  margin-bottom: 6rpx;
}

.family-member-name {
  font-size: 29rpx;
  font-weight: 700;
  color: #222;
  margin-right: 12rpx;
}

.family-member-role {
  font-size: 22rpx;
  color: #07c160;
  background: rgba(7,193,96,0.08);
  padding: 4rpx 14rpx;
  border-radius: 12rpx;
  margin-right: 10rpx;
}

.family-member-baby-tag {
  font-size: 20rpx;
  color: #888;
  background: #f5f5f5;
  padding: 4rpx 12rpx;
  border-radius: 10rpx;
}

.family-member-time {
  font-size: 22rpx;
  color: #999;
}

/* 创建者标签 */
.family-owner-tag {
  font-size: 22rpx;
  color: #07c160;
  background: rgba(7,193,96,0.1);
  padding: 6rpx 14rpx;
  border-radius: 16rpx;
  flex-shrink: 0;
}

/* 修改身份按钮 */
.family-role-btn {
  height: 52rpx;
  line-height: 52rpx;
  padding: 0 18rpx;
  border-radius: 26rpx;
  background: #f3f7f4;
  color: #07c160;
  font-size: 22rpx;
  flex-shrink: 0;
}

/* ========== 邀请区域 ========== */
.family-invite-area {
  margin-top: 36rpx;
  text-align: center;
}

.family-invite-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  width: 100%;
  height: 90rpx;
  border-radius: 16rpx;
  background: #07c160;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
}

.family-invite-hint {
  margin-top: 16rpx;
  font-size: 24rpx;
  color: #999;
}

/* ========== 弹窗通用 ========== */
.family-mask {
  position: fixed;
  left: 0;
  right: 0;
  top: 0;
  bottom: 0;
  z-index: 10000;
  background: rgba(0,0,0,0.4);
  display: flex;
  align-items: flex-end;
}

.family-sheet {
  width: 100%;
  background: #fff;
  border-radius: 24rpx 24rpx 0 0;
  padding: 32rpx 32rpx calc(40rpx + env(safe-area-inset-bottom));
  box-sizing: border-box;
}

.family-sheet-hd {
  display: flex;
  align-items: center;
  margin-bottom: 12rpx;
}

.family-sheet-title {
  flex: 1;
  font-size: 34rpx;
  font-weight: 700;
  color: #222;
}

.family-sheet-close {
  font-size: 40rpx;
  color: #bbb;
  padding: 8rpx;
}

.family-sheet-desc {
  font-size: 26rpx;
  line-height: 1.6;
  color: #666;
  margin-bottom: 24rpx;
}

/* ========== 筛选框 ========== */
.family-picker {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 20rpx;
  background: #f7fbf8;
  border-radius: 12rpx;
  margin-bottom: 20rpx;
}

.family-picker-label {
  font-size: 28rpx;
  color: #666;
}

.family-picker-value {
  font-size: 28rpx;
  color: #333;
  font-weight: 600;
}

.family-sheet-btn {
  display: flex;
  align-items: center;
  justify-content: center;
  margin-top: 8rpx;
  width: 100%;
  height: 88rpx;
  line-height: 1;
  padding: 0;
  box-sizing: border-box;
  border-radius: 16rpx;
  background: #07c160;
  color: #fff;
  font-size: 30rpx;
  font-weight: 700;
}

.family-sheet-btn::after {
  border: none;
}
