/* custom-tab-bar/index.wxss */

.tab-bar {
  position: fixed;
  left: 0;
  right: 0;
  bottom: 0;
  height: 100rpx;
  background: #fff;
  display: flex;
  border-top: 1rpx solid #f0f0f0;
  padding-bottom: env(safe-area-inset-bottom);
  z-index: 300;
  box-shadow: 0 -2rpx 12rpx rgba(0, 0, 0, 0.04);
}

.tab-item {
  flex: 1;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  position: relative;
}

.tab-icon {
  font-size: 40rpx;
  line-height: 1;
  margin-bottom: 4rpx;
}

.tab-text {
  font-size: 20rpx;
  color: #999;
  transition: color 0.2s;
}

.tab-item.active .tab-text {
  color: #07c160;
  font-weight: 500;
}
