/* components/activity-form/index.wxss */

.af-form { padding-bottom: 40rpx; }

.af-tabs {
  display: flex;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 6rpx;
  margin-bottom: 30rpx;
}

.af-tab {
  flex: 1;
  text-align: center;
  padding: 18rpx;
  font-size: 28rpx;
  border-radius: 8rpx;
  color: #666;
}

.af-tab.active {
  background: #fff;
  color: #10aeff;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0,0,0,0.06);
}

.section { margin-bottom: 30rpx; }

.label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.chip-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.chip {
  padding: 14rpx 24rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.chip-delete-entry {
  background: #fff5f5;
  border: 2rpx solid rgba(250, 81, 81, 0.35);
  color: #fa5151;
}

.chip.active {
  background: #e6f5ff;
  color: #10aeff;
  border-color: #10aeff;
}

.chip-custom {
  background: #fff;
  border: 2rpx dashed #ccc;
  color: #999;
}

.chip-custom.active {
  background: #e6f5ff;
  color: #10aeff;
  border-color: #10aeff;
}

.custom-input {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.custom-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 14rpx;
}

.custom-confirm {
  padding: 14rpx 28rpx;
  background: #10aeff;
  color: #fff;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.input-group { margin-bottom: 30rpx; }

.note-input {
  width: 100%;
  min-height: 120rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 18rpx 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.field-input {
  width: 100%;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker-value {
  height: 88rpx;
  line-height: 88rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #10aeff;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  margin-top: 20rpx;
  padding: 0;
  text-align: center;
  box-sizing: border-box;
}
