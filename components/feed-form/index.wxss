/* components/feed-form/index.wxss */

.feed-form {
  padding-bottom: 40rpx;
}

.type-tabs {
  display: flex;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 6rpx;
  margin-bottom: 36rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 18rpx;
  font-size: 28rpx;
  border-radius: 8rpx;
  color: #666;
}

.tab-item.active {
  background: #fff;
  color: #07c160;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.side-select,
.input-mode {
  margin-bottom: 30rpx;
}

.label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.side-options,
.mode-options {
  display: flex;
  gap: 20rpx;
}

.side-btn,
.mode-btn {
  flex: 1;
  text-align: center;
  padding: 20rpx;
  border-radius: 12rpx;
  background: #f5f5f5;
  font-size: 28rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.side-btn.active,
.mode-btn.active {
  background: #e8f9ef;
  color: #07c160;
  border-color: #07c160;
}

.timer-display {
  text-align: center;
  padding: 30rpx 0;
}

.timer-text {
  font-size: 72rpx;
  font-weight: bold;
  color: #333;
  font-family: 'Courier New', monospace;
  display: block;
  margin-bottom: 24rpx;
}

.timer-btn {
  width: 240rpx;
  height: 80rpx;
  line-height: 80rpx;
  border-radius: 40rpx;
  font-size: 28rpx;
  padding: 0;
}

.timer-btn.start {
  background: #07c160;
  color: #fff;
}

.timer-btn.stop {
  background: #ff4d4f;
  color: #fff;
}

.input-group {
  margin-bottom: 30rpx;
}

.note-input {
  width: 100%;
  min-height: 120rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 18rpx 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.field-input {
  width: 100%;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker-value {
  height: 88rpx;
  line-height: 88rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
}

/* 双侧计时 */
.side-timer {
  margin-bottom: 24rpx;
  background: #f9fafb;
  border-radius: 14rpx;
  padding: 20rpx 24rpx;
}

.side-timer-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-bottom: 14rpx;
}

.side-label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.side-acc {
  font-size: 22rpx;
  color: #10aeff;
  background: #e6f5ff;
  padding: 4rpx 14rpx;
  border-radius: 20rpx;
}

.side-timer-body {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 18rpx;
}

.side-timer-display {
  display: block;
  flex: 1;
  font-size: 56rpx;
  font-weight: bold;
  color: #999;
  font-family: 'Courier New', monospace;
  min-width: 210rpx;
  padding: 10rpx 0;
}

.side-timer-display.active {
  color: #07c160;
}

.side-timer-display.editable {
  color: #333;
}

.duration-picker {
  flex: 1;
}

.timer-btn.small {
  width: 100rpx;
  height: 64rpx;
  line-height: 64rpx;
  border-radius: 32rpx;
  font-size: 24rpx;
  padding: 0;
  margin: 0;
  flex-shrink: 0;
}

.timer-btn.small.start {
  background: #07c160;
  color: #fff;
}

.timer-btn.small.stop {
  background: #ff4d4f;
  color: #fff;
}

.total-timer {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 16rpx;
  padding: 20rpx;
  background: #e8f9ef;
  border-radius: 12rpx;
  margin-bottom: 24rpx;
}

.total-label {
  font-size: 26rpx;
  color: #666;
}

.total-value {
  font-size: 36rpx;
  font-weight: bold;
  color: #07c160;
  font-family: 'Courier New', monospace;
}

.manual-entry {
  font-size: 26rpx;
  color: #999;
  background: #f5f5f5;
  padding: 16rpx;
  border-radius: 8rpx;
  text-align: center;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #07c160;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  margin-top: 20rpx;
  padding: 0;
  text-align: center;
  box-sizing: border-box;
}
