/* components/abnormal-form/index.wxss */

.abnormal-form {
  padding-bottom: 40rpx;
}

.section {
  margin-bottom: 32rpx;
  padding: 24rpx;
  background: #fafafa;
  border-radius: 16rpx;
}

.section-header {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 18rpx;
}

.sub-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 12rpx;
  margin-top: 16rpx;
}

.chip-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.chip {
  padding: 14rpx 24rpx;
  border-radius: 8rpx;
  background: #fff;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid #eee;
}

.chip.active {
  background: #fff0e6;
  color: #e67e22;
  border-color: #e67e22;
}

.chip-danger.active-danger {
  background: #fff0f0;
  color: #e74c3c;
  border-color: #e74c3c;
}

.field-input {
  width: 100%;
  height: 88rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border: 1rpx solid #eee;
}

.input-group {
  margin-bottom: 20rpx;
}

.note-input {
  width: 100%;
  min-height: 120rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 18rpx 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  border: 1rpx solid #eee;
}

.photo-area {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
  margin-top: 16rpx;
}

.photo-thumb {
  position: relative;
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  overflow: hidden;
}

.photo-remove {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 32rpx;
  height: 32rpx;
  line-height: 30rpx;
  border-radius: 50%;
  text-align: center;
  font-size: 26rpx;
  color: #fff;
  background: rgba(0, 0, 0, 0.55);
}

.photo-thumb image {
  width: 100%;
  height: 100%;
}

.add-photo-btn {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  border: 2rpx dashed #ddd;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  font-size: 48rpx;
  color: #ccc;
  background: #fff;
}

.photo-tip {
  font-size: 20rpx;
  margin-top: 4rpx;
}

.picker-value {
  height: 88rpx;
  line-height: 88rpx;
  background: #fff;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
  border: 1rpx solid #eee;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  border-radius: 12rpx;
  font-size: 30rpx;
  margin-top: 20rpx;
  color: #fff;
  padding: 0;
  text-align: center;
  box-sizing: border-box;
}

.danger-save {
  background: linear-gradient(135deg, #e74c3c, #c0392b);
}
