/* components/growth-form/index.wxss */

.growth-form {
  padding-bottom: 40rpx;
}

.growth-hint {
  font-size: 24rpx;
  color: #999;
  text-align: center;
  margin-bottom: 30rpx;
}

.measure-cards {
  display: flex;
  gap: 24rpx;
  margin-bottom: 30rpx;
}

.measure-card {
  flex: 1;
  background: #f9f9f9;
  border-radius: 20rpx;
  padding: 30rpx;
  text-align: center;
}

.measure-icon {
  font-size: 48rpx;
  margin-bottom: 8rpx;
}

.measure-label {
  font-size: 26rpx;
  color: #999;
  margin-bottom: 18rpx;
}

.input-row {
  display: flex;
  align-items: center;
  justify-content: center;
  gap: 8rpx;
}

.measure-input {
  width: 120rpx;
  height: 72rpx;
  background: #fff;
  border-radius: 12rpx;
  text-align: center;
  font-size: 40rpx;
  font-weight: bold;
  color: #333;
}

.measure-unit {
  font-size: 28rpx;
  color: #999;
  font-weight: 500;
}

.input-group {
  margin-bottom: 30rpx;
}

.note-input {
  width: 100%;
  min-height: 120rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 18rpx 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.picker-value {
  height: 88rpx;
  line-height: 88rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #07c160;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  margin-top: 20rpx;
  padding: 0;
  text-align: center;
  box-sizing: border-box;
}
