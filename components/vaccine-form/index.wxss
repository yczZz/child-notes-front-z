/* components/vaccine-form/index.wxss */

.vaccine-form {
  padding-bottom: 40rpx;
}

.custom-vaccine-entry {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 20rpx 22rpx;
  margin-bottom: 22rpx;
  border-radius: 12rpx;
  background: #f8fafc;
  border: 1rpx solid #edf1f7;
}

.custom-vaccine-title {
  color: #1f2937;
  font-size: 28rpx;
  font-weight: 700;
}

.custom-vaccine-desc {
  margin-top: 5rpx;
  color: #8a94a3;
  font-size: 22rpx;
}

.custom-vaccine-plus {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 22rpx;
  background: #eef8ff;
  color: #0675b8;
  font-size: 22rpx;
  font-weight: 700;
}

.custom-vaccine-form {
  padding: 22rpx;
  margin-bottom: 24rpx;
  border-radius: 12rpx;
  background: #fff;
  border: 1rpx solid #edf1f7;
  box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.04);
}

.custom-vaccine-field {
  margin-bottom: 20rpx;
}

.custom-vaccine-label {
  margin-bottom: 10rpx;
  color: #667085;
  font-size: 24rpx;
}

.custom-vaccine-input,
.custom-vaccine-age-input {
  height: 76rpx;
  padding: 0 20rpx;
  border-radius: 10rpx;
  background: #f7f8fa;
  color: #1f2937;
  font-size: 26rpx;
  box-sizing: border-box;
}

.custom-vaccine-segments {
  display: flex;
  gap: 12rpx;
}

.custom-vaccine-segment {
  flex: 1;
  height: 68rpx;
  line-height: 68rpx;
  border-radius: 10rpx;
  text-align: center;
  background: #f3f8fc;
  color: #0675b8;
  font-size: 24rpx;
  font-weight: 700;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.custom-vaccine-segment.paid {
  background: #fff7ed;
  color: #b45309;
}

.custom-vaccine-segment.active {
  border-color: #10aeff;
  background: #eaf7ff;
}

.custom-vaccine-segment.paid.active {
  border-color: #f59e0b;
  background: #ffedd5;
}

.custom-vaccine-age-row {
  display: flex;
  gap: 12rpx;
}

.custom-vaccine-age-input {
  flex: 1;
  min-width: 0;
}

.custom-vaccine-unit {
  width: 148rpx;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 10rpx;
  background: #f7f8fa;
  color: #1f2937;
  font-size: 26rpx;
  text-align: center;
}

.custom-vaccine-actions {
  display: flex;
  gap: 14rpx;
  margin-top: 8rpx;
}

.custom-vaccine-cancel,
.custom-vaccine-save {
  flex: 1;
  height: 76rpx;
  line-height: 76rpx;
  border-radius: 38rpx;
  text-align: center;
  font-size: 26rpx;
  font-weight: 700;
}

.custom-vaccine-cancel {
  background: #f3f4f6;
  color: #667085;
}

.custom-vaccine-save {
  background: #10aeff;
  color: #fff;
}

.custom-vaccine-save.disabled {
  opacity: 0.58;
}

.vf-tabs {
  display: flex;
  background: #f5f7fb;
  border-radius: 12rpx;
  padding: 6rpx;
  margin-bottom: 24rpx;
}

.vf-tab {
  flex: 1;
  text-align: center;
  padding: 16rpx 10rpx;
  border-radius: 8rpx;
  color: #667085;
}

.vf-tab.active {
  background: #fff;
  color: #10aeff;
  box-shadow: 0 2rpx 8rpx rgba(16, 174, 255, 0.12);
}

.vf-tab-name {
  font-size: 28rpx;
  font-weight: 600;
}

.vf-tab-count {
  margin-top: 4rpx;
  font-size: 22rpx;
}

.selected-card {
  display: flex;
  align-items: center;
  justify-content: space-between;
  gap: 20rpx;
  padding: 22rpx 24rpx;
  margin-bottom: 24rpx;
  border-radius: 12rpx;
  background: #eef8ff;
  border: 1rpx solid #bfe8ff;
}

.selected-label {
  font-size: 22rpx;
  color: #5b7c99;
}

.selected-name {
  margin-top: 4rpx;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
}

.selected-meta {
  margin-top: 6rpx;
  font-size: 24rpx;
  color: #667085;
}

.selected-status {
  flex-shrink: 0;
  padding: 8rpx 16rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
}

.catalog-list {
  margin-bottom: 30rpx;
}

.vf-timeline {
  padding-top: 4rpx;
}

.vf-time-head,
.vf-time-row {
  display: flex;
  gap: 10rpx;
}

.vf-time-head {
  position: sticky;
  top: 0;
  z-index: 2;
  padding: 0 0 16rpx;
  background: #fff;
}

.vf-time-head-col,
.vf-time-head-axis {
  height: 44rpx;
  line-height: 44rpx;
  border-radius: 8rpx;
  font-size: 22rpx;
  font-weight: 700;
  text-align: center;
}

.vf-time-head-col {
  flex: 1;
  min-width: 0;
  background: #eef8ff;
  color: #0675b8;
}

.vf-time-head-col.paid {
  background: #fff7ed;
  color: #b45309;
}

.vf-time-head-axis {
  flex-shrink: 0;
  width: 124rpx;
  background: #f3f4f6;
  color: #667085;
}

.vf-time-row {
  align-items: stretch;
}

.vf-time-col {
  flex: 1;
  min-width: 0;
  padding-bottom: 26rpx;
}

.vf-time-axis {
  position: relative;
  flex-shrink: 0;
  width: 124rpx;
  display: flex;
  flex-direction: column;
  align-items: center;
  padding: 4rpx 0 26rpx;
  box-sizing: border-box;
}

.vf-time-line {
  position: absolute;
  left: 50%;
  top: 0;
  bottom: 0;
  width: 3rpx;
  transform: translateX(-50%);
  background: #d8e0ea;
}

.vf-time-dot {
  position: relative;
  z-index: 1;
  width: 18rpx;
  height: 18rpx;
  margin-top: 6rpx;
  border-radius: 50%;
  background: #10aeff;
  border: 5rpx solid #fff;
  box-shadow: 0 0 0 3rpx #bfe8ff;
}

.vf-time-label,
.vf-time-date,
.vf-time-count {
  position: relative;
  z-index: 1;
  max-width: 112rpx;
  text-align: center;
  word-break: break-all;
}

.vf-time-label {
  margin-top: 8rpx;
  font-size: 24rpx;
  font-weight: 700;
  color: #1f2937;
}

.vf-time-date {
  margin-top: 4rpx;
  color: #8a94a3;
  font-size: 19rpx;
}

.vf-time-count {
  margin-top: 6rpx;
  padding: 2rpx 8rpx;
  border-radius: 8rpx;
  background: #f3f4f6;
  color: #667085;
  font-size: 20rpx;
}

.vf-time-list {
  display: flex;
  flex-direction: column;
  gap: 12rpx;
}

.vf-time-dose {
  padding: 14rpx;
  border-radius: 10rpx;
  background: #fff;
  border: 2rpx solid #edf1f7;
  box-shadow: 0 2rpx 10rpx rgba(15, 23, 42, 0.04);
  box-sizing: border-box;
}

.vf-time-dose.active {
  border-color: #10aeff;
  box-shadow: 0 0 0 2rpx rgba(16, 174, 255, 0.12);
}

.vf-time-dose.done {
  background: #edfdf5;
  border-color: #9ee6c1;
}

.vf-time-dose.skipped {
  background: #f7f8fa;
  border-color: #d0d5dd;
}

.vf-time-dose.replaced {
  background: #ecfdf3;
  border-color: #9ee6c1;
}

.vf-time-dose.overdue {
  background: #fff4ed;
  border-color: #ffbf9b;
}

.vf-time-dose.due,
.vf-time-dose.soon {
  background: #fffbe8;
  border-color: #f4d35e;
}

.vf-time-dose-name {
  color: #1f2937;
  font-size: 24rpx;
  font-weight: 700;
  line-height: 1.35;
  word-break: break-all;
}

.vf-time-dose-meta {
  margin-top: 5rpx;
  color: #667085;
  font-size: 20rpx;
  line-height: 1.35;
  word-break: break-all;
}

.vf-time-dose-status {
  display: inline-block;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: rgba(255,255,255,0.74);
  color: #667085;
  font-size: 21rpx;
}

.vf-time-dose-footer {
  margin-top: 10rpx;
}

.vf-time-actions {
  display: flex;
  gap: 8rpx;
  margin-top: 10rpx;
}

.vf-time-action-picker {
  flex: 1;
  min-width: 0;
}

.vf-time-mark,
.vf-time-skip {
  flex: 1;
  min-width: 0;
  width: 100%;
  height: 48rpx;
  line-height: 48rpx;
  border-radius: 24rpx;
  text-align: center;
  font-size: 21rpx;
  box-sizing: border-box;
}

.vf-time-mark {
  background: #10aeff;
  color: #fff;
}

.vf-time-skip {
  background: #fff;
  color: #d45a1f;
  border: 1rpx solid #ffbf9b;
}

.vf-time-dose.done .vf-time-dose-status,
.vf-time-dose.replaced .vf-time-dose-status {
  color: #11845b;
}

.vf-time-dose.overdue .vf-time-dose-status {
  color: #d45a1f;
}

.vf-time-dose.due .vf-time-dose-status,
.vf-time-dose.soon .vf-time-dose-status {
  color: #9a6b00;
}

.vf-time-empty {
  min-height: 80rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  background: #f8fafc;
  color: #c0c6d0;
  font-size: 22rpx;
}

.vaccine-card {
  padding: 24rpx;
  margin-bottom: 20rpx;
  border-radius: 12rpx;
  background: #fff;
  border: 1rpx solid #eef0f4;
  box-shadow: 0 2rpx 12rpx rgba(15, 23, 42, 0.04);
}

.vaccine-head {
  display: flex;
  justify-content: space-between;
  align-items: flex-start;
  gap: 16rpx;
}

.vaccine-title {
  flex: 1;
  font-size: 30rpx;
  font-weight: 700;
  color: #1f2937;
}

.vaccine-progress {
  flex-shrink: 0;
  padding: 4rpx 12rpx;
  border-radius: 8rpx;
  background: #f3f4f6;
  color: #667085;
  font-size: 22rpx;
}

.vaccine-disease {
  margin-top: 8rpx;
  font-size: 24rpx;
  color: #667085;
  line-height: 1.5;
}

.dose-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
  margin-top: 18rpx;
}

.dose-chip {
  width: calc((100% - 14rpx) / 2);
  min-height: 128rpx;
  padding: 16rpx;
  border-radius: 10rpx;
  background: #f7f8fa;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.dose-chip.active {
  background: #eaf7ff;
  border-color: #10aeff;
}

.dose-chip.done {
  background: #edfdf5;
  border-color: #9ee6c1;
}

.dose-chip.skipped {
  background: #f7f8fa;
  border-color: #d0d5dd;
}

.dose-chip.replaced {
  background: #ecfdf3;
  border-color: #9ee6c1;
}

.dose-chip.overdue {
  background: #fff4ed;
  border-color: #ffbf9b;
}

.dose-chip.due,
.dose-chip.soon {
  background: #fffbe8;
  border-color: #f4d35e;
}

.dose-name {
  font-size: 26rpx;
  font-weight: 700;
  color: #1f2937;
}

.dose-age,
.dose-status {
  margin-top: 6rpx;
  font-size: 22rpx;
  color: #667085;
}

.dose-chip.done .dose-status,
.selected-status.done {
  color: #11845b;
}

.dose-chip.skipped .dose-status,
.selected-status.skipped {
  color: #667085;
}

.dose-chip.replaced .dose-status,
.selected-status.replaced {
  color: #168055;
}

.dose-chip.overdue .dose-status,
.selected-status.overdue {
  color: #d45a1f;
}

.dose-chip.due .dose-status,
.dose-chip.soon .dose-status,
.selected-status.due,
.selected-status.soon {
  color: #9a6b00;
}

.vaccine-remark {
  margin-top: 16rpx;
  padding: 14rpx 16rpx;
  border-radius: 8rpx;
  background: #f9fafb;
  color: #7a8493;
  font-size: 23rpx;
  line-height: 1.5;
}
