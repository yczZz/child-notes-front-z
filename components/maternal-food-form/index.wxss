/* components/maternal-food-form/index.wxss */

.maternal-food-form {
  padding-bottom: 40rpx;
}

.section {
  margin-bottom: 32rpx;
}

.section-title,
.label {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 18rpx;
}

.chip-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.chip {
  padding: 14rpx 24rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
  color: #666;
  font-size: 26rpx;
  border: 2rpx solid transparent;
}

.chip.active {
  background: #e8f9ef;
  color: #07c160;
  border-color: #07c160;
}

.chip-custom {
  background: #fff;
  color: #07c160;
  border-color: rgba(7, 193, 96, 0.45);
}

.chip-custom.active {
  background: #e8f9ef;
  border-color: #07c160;
}

.chip-add {
  background: #fff;
  border: 2rpx dashed #ccc;
  color: #999;
}

.chip-delete-entry {
  background: #fff5f5;
  border-color: rgba(250, 81, 81, 0.35);
  color: #fa5151;
}

.custom-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
}

.custom-input {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
}

.custom-confirm {
  padding: 14rpx 28rpx;
  background: #07c160;
  color: #fff;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.suspicion-grid {
  display: grid;
  grid-template-columns: repeat(2, minmax(0, 1fr));
  gap: 14rpx;
}

.suspicion-item {
  min-height: 76rpx;
  display: flex;
  align-items: center;
  justify-content: center;
  border-radius: 10rpx;
  background: #f5f5f5;
  color: #666;
  font-size: 26rpx;
  border: 2rpx solid transparent;
  box-sizing: border-box;
}

.suspicion-item.active {
  background: #e8f9ef;
  color: #07c160;
  border-color: #07c160;
  font-weight: 600;
}

.suspicion-item.warn.active {
  background: #fff5ec;
  color: #fa9d3b;
  border-color: #fa9d3b;
}

.note-input {
  width: 100%;
  min-height: 128rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 18rpx 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
  margin-bottom: 16rpx;
}

.photo-area {
  display: flex;
  flex-wrap: wrap;
  gap: 16rpx;
}

.photo-thumb {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  overflow: hidden;
  position: relative;
}

.photo-thumb image {
  width: 100%;
  height: 100%;
}

.photo-del {
  position: absolute;
  top: 4rpx;
  right: 4rpx;
  width: 36rpx;
  height: 36rpx;
  border-radius: 50%;
  background: rgba(0, 0, 0, 0.5);
  color: #fff;
  font-size: 26rpx;
  line-height: 36rpx;
  text-align: center;
}

.add-photo-btn {
  width: 120rpx;
  height: 120rpx;
  border-radius: 12rpx;
  border: 2rpx dashed #ddd;
  display: flex;
  flex-direction: column;
  align-items: center;
  justify-content: center;
  background: #fff;
}

.add-icon {
  font-size: 48rpx;
  color: #ccc;
  line-height: 1;
}

.add-text {
  font-size: 20rpx;
  color: #ccc;
  margin-top: 4rpx;
}

.input-group {
  margin-bottom: 30rpx;
}

.picker-value {
  height: 88rpx;
  line-height: 88rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #07c160;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  margin-top: 20rpx;
  padding: 0;
  text-align: center;
  box-sizing: border-box;
}
