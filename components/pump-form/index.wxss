/* components/pump-form/index.wxss */

.pump-form {
  padding-bottom: 40rpx;
}

.section {
  margin-bottom: 30rpx;
}

.section-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
  margin-bottom: 18rpx;
}

.dual-input {
  display: flex;
  gap: 20rpx;
}

.dual-item {
  flex: 1;
}

.dual-label {
  font-size: 24rpx;
  color: #999;
  margin-bottom: 10rpx;
}

.field-input {
  width: 100%;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.total-row {
  display: flex;
  align-items: center;
  justify-content: space-between;
  margin-top: 20rpx;
  padding: 20rpx 24rpx;
  background: #e8f9ef;
  border-radius: 12rpx;
}

.total-label {
  font-size: 28rpx;
  color: #333;
  font-weight: 500;
}

.total-value {
  font-size: 32rpx;
  color: #07c160;
  font-weight: 700;
}

.input-group {
  margin-bottom: 30rpx;
}

.label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.note-input {
  width: 100%;
  min-height: 100rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 18rpx 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker-value {
  height: 88rpx;
  line-height: 88rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #07c160;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  margin-top: 20rpx;
  padding: 0;
  text-align: center;
  box-sizing: border-box;
}
