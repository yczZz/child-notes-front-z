/* components/supplement-form/index.wxss */

.supplement-form {
  padding-bottom: 40rpx;
}

.type-tabs {
  display: flex;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 6rpx;
  margin-bottom: 36rpx;
}

.tab-item {
  flex: 1;
  text-align: center;
  padding: 18rpx;
  font-size: 28rpx;
  border-radius: 8rpx;
  color: #666;
}

.tab-item.active {
  background: #fff;
  color: #07c160;
  font-weight: 600;
  box-shadow: 0 2rpx 8rpx rgba(0, 0, 0, 0.06);
}

.input-group {
  margin-bottom: 30rpx;
}

.chip-grid {
  display: flex;
  flex-wrap: wrap;
  gap: 14rpx;
}

.chip {
  padding: 14rpx 24rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
  font-size: 26rpx;
  color: #666;
  border: 2rpx solid transparent;
}

.chip-delete-entry {
  background: #fff5f5;
  border: 2rpx solid rgba(250, 81, 81, 0.35);
  color: #fa5151;
}

.chip.active {
  background: #e8f9ef;
  color: #07c160;
  border-color: #07c160;
}

.chip-custom {
  background: #fff;
  color: #07c160;
  border-color: rgba(7, 193, 96, 0.45);
}

.chip-add {
  background: #fff;
  border: 2rpx dashed #ccc;
  color: #999;
}

.custom-row {
  display: flex;
  align-items: center;
  gap: 16rpx;
  margin-top: 16rpx;
}

.custom-input {
  flex: 1;
  height: 72rpx;
  background: #f5f5f5;
  border-radius: 8rpx;
  padding: 0 20rpx;
  font-size: 26rpx;
  box-sizing: border-box;
}

.custom-confirm {
  padding: 14rpx 28rpx;
  background: #07c160;
  color: #fff;
  border-radius: 8rpx;
  font-size: 26rpx;
}

.label {
  font-size: 28rpx;
  color: #666;
  margin-bottom: 16rpx;
}

.field-input {
  width: 100%;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.dose-row {
  margin-bottom: 16rpx;
}

.dose-input {
  width: 100%;
  height: 88rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.dose-units {
  display: flex;
  flex-wrap: wrap;
  gap: 12rpx;
}

.unit-btn {
  min-width: 64rpx;
  padding: 14rpx 16rpx;
  border-radius: 8rpx;
  background: #f5f5f5;
  border: 2rpx solid transparent;
  color: #666;
  font-size: 26rpx;
  text-align: center;
  box-sizing: border-box;
}

.unit-btn.active {
  background: #e8f9ef;
  color: #07c160;
  border-color: #07c160;
  font-weight: 600;
}

.unit-custom {
  background: #fff;
  color: #07c160;
  border-color: rgba(7, 193, 96, 0.45);
}

.unit-add {
  background: #fff;
  border: 2rpx dashed #ccc;
  color: #999;
}

.unit-delete {
  background: #fff5f5;
  border-color: rgba(250, 81, 81, 0.35);
  color: #fa5151;
}

.unit-custom-row {
  margin-top: 16rpx;
}

.note-input {
  width: 100%;
  min-height: 100rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 18rpx 24rpx;
  font-size: 28rpx;
  box-sizing: border-box;
}

.picker-value {
  height: 88rpx;
  line-height: 88rpx;
  background: #f5f5f5;
  border-radius: 12rpx;
  padding: 0 24rpx;
  font-size: 28rpx;
  color: #333;
}

.save-btn {
  width: 100%;
  height: 88rpx;
  line-height: 88rpx;
  background: #07c160;
  color: #fff;
  border-radius: 12rpx;
  font-size: 30rpx;
  margin-top: 20rpx;
  padding: 0;
  text-align: center;
  box-sizing: border-box;
}
