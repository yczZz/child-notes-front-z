/* components/diarrhea-tracker/index.wxss */

.dt-panel {
  margin: 16rpx 24rpx;
  background: linear-gradient(135deg, #fff8f0, #fffaf5);
  border-radius: 16rpx;
  overflow: hidden;
  box-shadow: 0 2rpx 16rpx rgba(0,0,0,0.04);
}

.dt-hd {
  display: flex;
  align-items: center;
  justify-content: space-between;
  padding: 24rpx 28rpx 0;
}

.dt-hd-left {
  display: flex;
  align-items: center;
  gap: 10rpx;
}

.dt-icon { font-size: 36rpx; }

.dt-title {
  font-size: 28rpx;
  font-weight: 600;
  color: #fa9d3b;
}

.dt-tag {
  font-size: 22rpx;
  color: #fa9d3b;
  background: #fff;
  padding: 4rpx 14rpx;
  border-radius: 16rpx;
  border: 1rpx solid rgba(250,157,59,0.2);
}

.dt-bd {
  display: flex;
  margin: 18rpx 28rpx;
  padding: 22rpx 20rpx;
  background: #fff;
  border-radius: 12rpx;
}

.dt-item {
  flex: 1;
  text-align: center;
}

.dt-label {
  font-size: 22rpx;
  color: #999;
  margin-bottom: 6rpx;
}

.dt-value {
  font-size: 28rpx;
  font-weight: 600;
  color: #333;
}

.dt-value.warn { color: #fa9d3b; }

.dt-split {
  width: 2rpx;
  background: #f0f0f0;
}

.dt-tips {
  margin: 0 28rpx 14rpx;
  padding: 16rpx 20rpx;
  background: #fff;
  border-radius: 12rpx;
}

.dt-tip {
  font-size: 24rpx;
  color: #999;
  padding: 6rpx 0;
}

.dt-actions {
  display: flex;
  gap: 16rpx;
  padding: 0 28rpx;
}

.dt-btn {
  flex: 1;
  text-align: center;
  padding: 16rpx;
  border-radius: 10rpx;
  font-size: 26rpx;
  color: #fa9d3b;
  background: #fff;
  border: 2rpx solid #fa9d3b;
}

.dt-btn-fill {
  color: #fff;
  background: #fa9d3b;
}

.dt-recovered {
  text-align: center;
  padding: 16rpx 0 24rpx;
}

.dt-recovered-btn {
  display: inline-block;
  padding: 10rpx 40rpx;
  border: 1rpx solid #07c160;
  color: #07c160;
  border-radius: 32rpx;
  font-size: 26rpx;
}
