/* components/record-drawer/index.wxss */

.drawer-mask {
  position: fixed;
  top: 0;
  left: 0;
  right: 0;
  bottom: 0;
  background: rgba(0, 0, 0, 0.5);
  z-index: 999;
  opacity: 0;
  visibility: hidden;
  transition: opacity 0.3s, visibility 0.3s;
}

.drawer-mask.show {
  opacity: 1;
  visibility: visible;
}

.drawer-panel {
  position: fixed;
  left: 0;
  right: 0;
  bottom: calc(100rpx + env(safe-area-inset-bottom));
  background: #fff;
  border-radius: 32rpx 32rpx 0 0;
  z-index: 1000;
  max-height: 85vh;
  transform: translateY(100%);
  transition: transform 0.3s ease;
}

.drawer-panel.show {
  transform: translateY(0);
}

.drawer-header {
  display: flex;
  align-items: center;
  justify-content: center;
  padding: 24rpx 32rpx 16rpx;
  position: relative;
  border-bottom: 1rpx solid #f0f0f0;
}

.drawer-handle {
  width: 60rpx;
  height: 6rpx;
  background: #ddd;
  border-radius: 3rpx;
  position: absolute;
  top: 12rpx;
  left: 50%;
  transform: translateX(-50%);
}

.drawer-title {
  font-size: 32rpx;
  font-weight: 600;
  color: #333;
}

.drawer-close {
  position: absolute;
  right: 32rpx;
  top: 50%;
  transform: translateY(-50%);
  font-size: 32rpx;
  color: #999;
  padding: 10rpx;
}

.drawer-body {
  max-height: 70vh;
  padding: 30rpx 32rpx;
  box-sizing: border-box;
}
